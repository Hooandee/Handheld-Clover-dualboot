#!/bin/bash
#
# clover-ctl - non-interactive engine for the Clover dual-boot tools.
# The desktop app and the Decky plugin both call this; it does the real work
# so the logic lives in one place. Mutating commands need root (the frontends
# elevate via pkexec or Decky's root backend). Set CLOVER_CONFIG to point the
# read / config-write commands at a specific config.plist (used by the tests).

set -u

detect_os() {
	if grep -qi bazzite /etc/os-release 2> /dev/null
	then
		OS=bazzite; EFI_PATH=/boot/efi/EFI; BOOTX64=$EFI_PATH/BOOT/BOOTX64.EFI
	elif grep -qi steamos /etc/os-release 2> /dev/null
	then
		OS=SteamOS; EFI_PATH=/esp/efi; BOOTX64=$EFI_PATH/boot/bootx64.efi
	else
		OS=unknown; EFI_PATH=; BOOTX64=
	fi
}
detect_os
CONFIG=${CLOVER_CONFIG:-${EFI_PATH:+$EFI_PATH/clover/config.plist}}

die() { echo "clover-ctl: $1" >&2; exit 1; }
need_efi() { [ -n "$EFI_PATH" ] || die "not running on SteamOS or Bazzite"; }

# root is required for the real install paths; the test suite opts out explicitly
need_root() {
	[ "${CLOVER_CTL_ALLOW_NONROOT:-}" = 1 ] && return 0
	[ "$(id -u)" = 0 ] || die "must run as root (try: sudo clover-ctl $CMD ...)"
}

# value of a <key> in a plist - the text on the following line, tags stripped
plist_get() {
	awk -v k="<key>$1</key>" '
		f { sub(/^[[:space:]]*<[^>]*>/, ""); sub(/<\/[^>]*>[[:space:]]*$/, ""); print; exit }
		index($0, k) { f = 1 }
	' "$2" 2> /dev/null
}

# rewrite the value line after a <key>; portable (BSD/GNU) and backslash-safe via ENVIRON
plist_set() {
	PLIST_VAL=$3 awk -v k="<key>$1</key>" -v tag="$2" '
		repl { print "\t\t<" tag ">" ENVIRON["PLIST_VAL"] "</" tag ">"; repl = 0; next }
		{ print }
		index($0, k) { repl = 1 }
	' "$4" > "$4.cloverctl.tmp" && mv "$4.cloverctl.tmp" "$4"
}

# native panel resolution from the kernel, normalized to landscape (panels are often mounted rotated)
detect_native_resolution() {
	local modes res w h
	for modes in /sys/class/drm/*eDP*/modes /sys/class/drm/*DSI*/modes /sys/class/drm/*LVDS*/modes
	do
		[ -f "$modes" ] || continue
		res=$(head -n1 "$modes" 2> /dev/null)
		case "$res" in *x*) ;; *) continue ;; esac
		w=${res%%x*}; h=${res##*x}
		case "$w$h" in *[!0-9]*) continue ;; esac
		[ "$h" -gt "$w" ] && echo "${h}x${w}" || echo "${w}x${h}"
		return 0
	done
	return 1
}

# map a DefaultLoader path + DefaultVolume to a friendly OS name (loader paths in
# config.plist are mixed/upper case, so lowercase before matching)
default_os_label() {
	local loader; loader=$(printf '%s' "$1" | tr 'A-Z' 'a-z')
	case "$2" in *LastBootedVolume*) echo lastos; return ;; esac
	case "$loader" in
		*microsoft*) echo windows ;;
		*steamcl*) echo steamos ;;
		*fedora*|*shimx64*) echo bazzite ;;
		*) echo unknown ;;
	esac
}

# read every status field in a single pass: resolution|theme|timeout|loader|volume
plist_get_all() {
	awk '
		function val(s) { sub(/^[[:space:]]*<[^>]*>/, "", s); sub(/<\/[^>]*>[[:space:]]*$/, "", s); return s }
		/<key>ScreenResolution<\/key>/ { getline; r = val($0) }
		/<key>Theme<\/key>/            { getline; t = val($0) }
		/<key>Timeout<\/key>/          { getline; o = val($0) }
		/<key>DefaultLoader<\/key>/    { getline; l = val($0) }
		/<key>DefaultVolume<\/key>/    { getline; v = val($0) }
		END { print r "|" t "|" o "|" l "|" v }
	' "$1" 2> /dev/null
}

json_bool() { [ "$1" = yes ] && echo true || echo false; }

CMD=${1:-help}
shift 2> /dev/null || true

case "$CMD" in
status)
	if [ -n "$CONFIG" ] && [ -f "$CONFIG" ]; then installed=yes; else installed=no; fi
	if systemctl is-enabled clover-bootmanager &> /dev/null; then service=enabled
	elif systemctl list-unit-files clover-bootmanager.service &> /dev/null; then service=disabled
	else service=absent; fi
	if [ -n "$EFI_PATH" ] && [ -e "$EFI_PATH/Microsoft/Boot/bootmgfw.efi" ]; then winactive=yes; else winactive=no; fi
	IFS='|' read -r res theme timeout loader volume < <(plist_get_all "$CONFIG")
	printf '{"os":"%s","installed":%s,"resolution":"%s","theme":"%s","timeout":"%s","default_os":"%s","service":"%s","windows_active":%s}\n' \
		"$OS" "$(json_bool $installed)" "$res" "$theme" "$timeout" \
		"$(default_os_label "$loader" "$volume")" "$service" "$(json_bool $winactive)"
	;;
get)
	case "${1:-}" in
		resolution) plist_get ScreenResolution "$CONFIG" ;;
		theme) plist_get Theme "$CONFIG" ;;
		timeout) plist_get Timeout "$CONFIG" ;;
		default-os) default_os_label "$(plist_get DefaultLoader "$CONFIG")" "$(plist_get DefaultVolume "$CONFIG")" ;;
		*) die "usage: clover-ctl get <resolution|theme|timeout|default-os>" ;;
	esac
	;;
list-themes)
	need_efi
	ls "$EFI_PATH/clover/themes" 2> /dev/null
	;;
detect-resolution)
	detect_native_resolution
	;;
set-resolution)
	need_root
	val=${1:-}
	[ "$val" = auto ] && val=$(detect_native_resolution)
	[ -n "$val" ] || die "no resolution given and auto-detect failed"
	case "$val" in [0-9]*x[0-9]*) ;; *) die "invalid resolution: $val (expected WxH)" ;; esac
	plist_set ScreenResolution string "$val" "$CONFIG"
	echo "resolution set to $val"
	;;
set-theme)
	need_root
	[ -n "${1:-}" ] || die "usage: clover-ctl set-theme <name>"
	plist_set Theme string "$1" "$CONFIG"
	echo "theme set to $1"
	;;
set-timeout)
	need_root
	case "${1:-}" in ''|*[!0-9]*) die "usage: clover-ctl set-timeout <seconds>" ;; esac
	plist_set Timeout integer "$1" "$CONFIG"
	echo "timeout set to $1"
	;;
set-default-os)
	need_root
	case "${1:-}" in
		windows) plist_set DefaultLoader string '\efi\microsoft\bootmgfw.efi' "$CONFIG"; plist_set DefaultVolume string esp "$CONFIG" ;;
		steamos) plist_set DefaultLoader string '\efi\steamos\steamcl.efi' "$CONFIG"; plist_set DefaultVolume string esp "$CONFIG" ;;
		bazzite) plist_set DefaultLoader string '\EFI\FEDORA\shimx64.efi' "$CONFIG"; plist_set DefaultVolume string esp "$CONFIG" ;;
		lastos) plist_set DefaultVolume string LastBootedVolume "$CONFIG" ;;
		*) die "usage: clover-ctl set-default-os <windows|steamos|bazzite|lastos>" ;;
	esac
	echo "default boot set to $1"
	;;
service)
	need_root; need_efi
	case "${1:-}" in
		disable)
			[ -f "$EFI_PATH/Microsoft/Boot/bootmgfw.efi.orig" ] || die "Windows EFI backup missing - refusing to disable Clover so Windows stays bootable"
			cp "$EFI_PATH/Microsoft/Boot/bootmgfw.efi.orig" "$EFI_PATH/Microsoft/Boot/bootmgfw.efi" || die "could not restore Windows EFI - leaving Clover enabled"
			win=$(efibootmgr | grep -i Windows | colrm 9 | colrm 1 4)
			[ -n "$win" ] && efibootmgr -n "$win" &> /dev/null
			systemctl disable --now clover-bootmanager
			echo "clover service disabled - Windows will boot next"
			;;
		enable)
			systemctl enable --now clover-bootmanager
			[ -x /etc/systemd/system/clover-bootmanager.sh ] && /etc/systemd/system/clover-bootmanager.sh
			echo "clover service enabled"
			;;
		*) die "usage: clover-ctl service <enable|disable>" ;;
	esac
	;;
install-decky)
	need_root
	user=${SUDO_USER:-$(id -un 1000 2> /dev/null || echo deck)}
	home=$(getent passwd "$user" | cut -d: -f6)
	[ -n "$home" ] || home="/home/$user"
	[ -d "$home/homebrew" ] || die "Decky Loader not found at $home/homebrew - install Decky first"
	dest="$home/homebrew/plugins/Clover Dual Boot"
	# use a local prebuilt plugin if present, otherwise download the prebuilt release
	src=""
	for d in "$home/1Clover-tools/decky" "$(dirname "$0")/decky" "$(dirname "$0")/../decky"
	do
		[ -f "$d/dist/index.js" ] && { src="$d"; break; }
	done
	tmp=""
	if [ -z "$src" ]
	then
		url=${DECKY_PLUGIN_URL:-https://github.com/Hooandee/Handheld-Clover-dualboot/releases/latest/download/clover-dualboot-decky.zip}
		tmp=$(mktemp -d)
		echo "No local build found - downloading the prebuilt plugin..."
		if curl -fsSL "$url" -o "$tmp/p.zip" && python3 -c "
import zipfile, os
dest = os.path.realpath('$tmp')
with zipfile.ZipFile('$tmp/p.zip') as z:
    for m in z.namelist():
        p = os.path.realpath(os.path.join(dest, m))
        if p != dest and not p.startswith(dest + os.sep):
            raise SystemExit('unsafe path in zip: ' + m)
    z.extractall(dest)
"
		then
			src=$(dirname "$(find "$tmp" -name plugin.json 2> /dev/null | head -n1)")
		fi
		{ [ -n "$src" ] && [ -f "$src/dist/index.js" ]; } || { rm -rf "$tmp"; die "no built plugin available - run 'cd decky && pnpm build', or check your connection"; }
	fi
	mkdir -p "$dest/dist"
	cp "$src/plugin.json" "$src/main.py" "$dest/" && cp "$src/dist/index.js" "$dest/dist/" || { [ -n "$tmp" ] && rm -rf "$tmp"; die "failed to copy plugin into $dest"; }
	chown -R "$user":"$user" "$dest" 2> /dev/null || true
	[ -n "$tmp" ] && rm -rf "$tmp"
	systemctl restart plugin_loader 2> /dev/null && echo "Decky restarted." || echo "Installed - reload Decky to see it."
	echo "Decky plugin installed to: $dest"
	;;
diagnostics)
	need_root
	user=${SUDO_USER:-$(id -un 1000 2> /dev/null || echo "$USER")}
	home=$(getent passwd "$user" | cut -d: -f6)
	[ -n "$home" ] || home="$HOME"
	out="$home/clover-report-$(date +%Y%m%d-%H%M%S).txt"
	{
		echo "# Clover diagnostics - $(date)"
		echo; echo "## OS"; grep -E 'PRETTY_NAME|VERSION_ID|BUILD_ID' /etc/os-release 2> /dev/null
		echo; echo "## Device (DMI)"
		for f in sys_vendor product_name board_name; do echo "$f: $(cat /sys/class/dmi/id/$f 2> /dev/null)"; done
		echo; echo "## clover-ctl status"; "$0" status 2>&1
		echo; echo "## EFI boot entries"; efibootmgr 2>&1 | grep -iv 'Boot2\|PXE'
		echo; echo "## config.plist"; grep -A1 -E 'ScreenResolution|<key>Theme|<key>Timeout|DefaultLoader|DefaultVolume' "$CONFIG" 2> /dev/null
		echo; echo "## boot-manager status"; cat "$home/1Clover-tools/status.txt" 2> /dev/null
		echo; echo "## service log"; journalctl -u clover-bootmanager -n 40 --no-pager 2> /dev/null
	} > "$out" 2>&1
	chown "$user":"$user" "$out" 2> /dev/null || true
	echo "$out"
	;;
set-batocera)
	need_root
	case "${1:-}" in
		v39) loader='\efi\batocera\grubx64.efi' ;;
		v38) loader='\efi\boot\bootx64.efi' ;;
		*) die "usage: clover-ctl set-batocera <v38|v39>" ;;
	esac
	PLIST_VAL="$loader" awk '
		s == 2 { print "\t\t\t\t\t<string>" ENVIRON["PLIST_VAL"] "</string>"; s = 0; next }
		s == 1 { s = 2; print; next }
		{ print }
		/<string>os_batocera<\/string>/ { s = 1 }
	' "$CONFIG" > "$CONFIG.cloverctl.tmp" && mv "$CONFIG.cloverctl.tmp" "$CONFIG"
	echo "batocera config set to $1"
	;;
list-logos)
	home=$(getent passwd "${SUDO_USER:-$(id -un 1000 2> /dev/null)}" | cut -d: -f6)
	[ -n "$home" ] || home="$HOME"
	ls "$home/1Clover-tools/logos" 2> /dev/null | grep -i '\.png$'
	;;
set-logo)
	need_root; need_efi
	home=$(getent passwd "${SUDO_USER:-$(id -un 1000 2> /dev/null)}" | cut -d: -f6)
	[ -n "$home" ] || home="$HOME"
	[ -n "${1:-}" ] || die "usage: clover-ctl set-logo <name.png>"
	src="$home/1Clover-tools/logos/$1"
	[ -f "$src" ] || die "logo not found: $src"
	mkdir -p "$EFI_PATH/steamos"
	cp "$src" "$EFI_PATH/steamos/steamos.png"
	echo "boot logo set to $1"
	;;
reset-logo)
	need_root; need_efi
	rm -f "$EFI_PATH/steamos/steamos.png"
	echo "boot logo restored to default"
	;;
uninstall)
	need_root; need_efi
	home=$(getent passwd "${SUDO_USER:-$(id -un 1000 2> /dev/null)}" | cut -d: -f6)
	[ -n "$home" ] || home="$HOME"
	if [ -f "$EFI_PATH/Microsoft/Boot/bootmgfw.efi.orig" ]
	then
		mv "$EFI_PATH/Microsoft/Boot/bootmgfw.efi.orig" "$EFI_PATH/Microsoft/Boot/bootmgfw.efi" && rm -f "$EFI_PATH/Microsoft/bootmgfw.efi"
	fi
	[ -f "$BOOTX64.orig" ] && mv "$BOOTX64.orig" "$BOOTX64"
	rm -rf "$EFI_PATH/clover"
	rm -f "$EFI_PATH/steamos/steamos.png"
	for e in $(efibootmgr 2> /dev/null | grep "Clover - GUI" | colrm 9 | colrm 1 4)
	do
		efibootmgr -b "$e" -B &> /dev/null
	done
	ro=$(command -v steamos-readonly)
	[ -n "$ro" ] && steamos-readonly disable 2> /dev/null
	systemctl disable --now clover-bootmanager.service &> /dev/null
	rm -f /etc/systemd/system/clover-bootmanager*
	systemctl daemon-reload 2> /dev/null
	rm -f /etc/atomic-update.conf.d/clover-whitelist.conf
	[ -n "$ro" ] && steamos-readonly enable 2> /dev/null
	rm -f "$home/.local/share/kservices5/ServiceMenus/open_as_root.desktop"
	rm -f "$home/.local/share/applications/clover-dualboot.desktop" "$home/Desktop/clover-dualboot.desktop" "$home/Desktop/Clover-Toolbox"
	rm -rf "$home/1Clover-tools"
	echo "Clover uninstalled - reboot to return to Windows."
	;;
theme-preview)
	need_root; need_efi
	name=${1:-}
	[ -n "$name" ] || die "usage: clover-ctl theme-preview <name>"
	case "$name" in */*) die "invalid theme name" ;; esac
	dir="$EFI_PATH/clover/themes/$name"
	[ -d "$dir" ] || die "theme not found: $name"
	img=$(ls "$dir" 2> /dev/null | grep -iE '\.(png|jpg|jpeg)$' | grep -i background | head -n1)
	[ -n "$img" ] || img=$(ls "$dir" 2> /dev/null | grep -iE 'screenshot.*\.(png|jpg|jpeg)$' | head -n1)
	[ -n "$img" ] || img=$(ls "$dir" 2> /dev/null | grep -iE '\.(png|jpg|jpeg)$' | head -n1)
	[ -n "$img" ] || die "no preview image in theme $name"
	out="/tmp/clover-theme-preview.png"
	cp "$dir/$img" "$out" && chmod 644 "$out"
	echo "$out"
	;;
help|--help|-h)
	cat <<'USAGE'
clover-ctl <command> [args]
  status                                            current config + state as JSON
  get <resolution|theme|timeout|default-os>         read one value
  list-themes                                       installed Clover themes
  detect-resolution                                 native panel resolution
  set-resolution <WxH|auto>                         (root)
  set-theme <name>                                  (root)
  set-timeout <seconds>                             (root)
  set-default-os <windows|steamos|bazzite|lastos>   (root)
  service <enable|disable>                          (root) enable Clover, or hand next boot to Windows
  install-decky                                     (root) install/update the Decky (Game Mode) plugin
  diagnostics                                       (root) write a bug-report bundle to your home folder
  set-batocera <v38|v39>                            (root) point the Batocera entry at the right loader
  list-logos                                        list available boot logos
  set-logo <name.png>                               (root) set the boot (BGRT) logo
  reset-logo                                        (root) restore the default boot logo
  uninstall                                         (root) remove Clover and restore the Windows bootloader
  theme-preview <name>                              (root) copy a theme's preview image to /tmp, print the path
USAGE
	;;
*)
	die "unknown command: $CMD (try: clover-ctl help)"
	;;
esac
