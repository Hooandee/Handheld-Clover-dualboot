#!/bin/bash
#
# Launches the Clover desktop app. On first run it builds a self-contained
# PySide6 virtualenv under ~/1Clover-tools/venv, so nothing is installed into
# the (immutable) SteamOS / Bazzite system.

set -e
HERE=$(cd "$(dirname "$0")" && pwd)
VENV="${CLOVER_VENV:-$HOME/1Clover-tools/venv}"
PY="$VENV/bin/python"

if [ ! -x "$PY" ]
then
	echo "First run: preparing the UI environment (downloads PySide6, one time)..."
	python3 -m venv "$VENV"
	"$VENV/bin/pip" install --upgrade pip > /dev/null
	"$VENV/bin/pip" install PySide6 pillow || { echo "Could not install PySide6 - is there network access?"; exit 1; }
fi

# ensure Pillow is present (renders .icns theme icons); covers venvs made before it was added
"$PY" -c "import PIL" 2> /dev/null || "$VENV/bin/pip" install pillow > /dev/null 2>&1 || true

exec "$PY" "$HERE/clover_desktop.py" "$@"
